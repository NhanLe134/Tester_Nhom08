# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (change this in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
# 
# Render PostgreSQL Example:
# DATABASE_URL=postgresql://user:password@dpg-xxxxx.oregon-postgres.render.com/dbname
#
# Local PostgreSQL Example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/taphoanga
DATABASE_URL=

# Frontend URL (for CORS) - Optional, defaults to localhost:5173
# Local: http://localhost:5173
# Production: https://tester-nhom08.vercel.app
FRONTEND_URL=http://localhost:5173
